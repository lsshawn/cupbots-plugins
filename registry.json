{
  "version": 1,
  "api": "https://api.cupbots.dev",
  "plugins": {
    "bookmarks": {
      "name": "bookmarks",
      "description": "Save, search, and manage bookmarked links",
      "version": "1.0.0",
      "author": "CupBots",
      "commands": [
        "/bookmark",
        "/bookmarks",
        "/unbookmark"
      ],
      "config": [],
      "free": true,
      "bundled": true,
      "files": [
        "plugins/bookmarks.py"
      ]
    },
    "calendar": {
      "name": "calendar",
      "description": "Calendar management via CalDAV",
      "version": "1.0.0",
      "author": "CupBots",
      "commands": [
        "/today",
        "/day",
        "/week",
        "/next",
        "/agenda",
        "/free",
        "/event",
        "/delete",
        "/holidays",
        "/cal"
      ],
      "config": [
        {
          "key": "CALDAV_URL",
          "label": "CalDAV Server URL",
          "type": "text",
          "required": true,
          "help": "e.g. https://radicale.example.com/user/calendar/"
        },
        {
          "key": "CALDAV_USERNAME",
          "label": "CalDAV Username",
          "type": "text",
          "required": true
        },
        {
          "key": "CALDAV_PASSWORD",
          "label": "CalDAV Password",
          "type": "secret",
          "required": true
        }
      ],
      "free": true,
      "bundled": true,
      "files": [
        "plugins/calendar_plugin.py"
      ]
    },
    "calendar_briefing": {
      "name": "calendar_briefing",
      "description": "Calendar briefing with tomorrow and week-ahead views",
      "version": "1.0.0",
      "author": "CupBots",
      "commands": [
        "/briefing",
        "/tomorrow",
        "/weekahead"
      ],
      "config": [],
      "requires": [
        "calendar"
      ],
      "free": true,
      "bundled": true,
      "files": [
        "plugins/calendar_briefing.py"
      ]
    },
