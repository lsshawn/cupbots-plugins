{
  "name": "calendar",
  "description": "Calendar management via CalDAV or Google Calendar",
  "version": "1.8.0",
  "author": "CupBots",
  "commands": [
    "/cal",
    "/event"
  ],
  "write_commands": [
    "/event"
  ],
  "primitives": [
    "/cal                                       — today's events",
    "/cal week                                  — next 7 days",
    "/cal <N>                                   — next N days (e.g. /cal 5)",
    "/cal <date>                                — events on a date (e.g. /cal 8 apr)",
    "/cal free [date]                           — free slots",
    "/event create --title X --start 2026-04-09T14:00 --end 2026-04-09T15:00 [--location L] [--rrule R]",
    "/event create --title X --start 2026-04-09T14:00 --duration 30m",
    "/event delete --uid <uid>                  — delete by exact UID (get UID from /event search)",
    "/event delete --query \"standup\"            — delete by keyword",
    "/event search --query \"standup\" [--days 30] — list matching events with UIDs"
  ],
  "intent": "Create, view, edit, or delete calendar events, meetings, appointments, huddles. Recurring event schedules. Manage availability preferences (no weekends, work hours) and refuse overlapping events.",
  "not_intent": "Sending WhatsApp messages to someone at a scheduled time",
  "config": [
    [
      [
        "key",
        "calendar_backend"
      ],
      [
        "label",
        "Calendar backend"
      ],
      [
        "type",
        "text"
      ],
      [
        "required",
        false
      ],
      [
        "help",
        "caldav (default) or google"
      ]
    ],
    [
      [
        "key",
        "caldav_url"
      ],
      [
        "label",
        "CalDAV Server URL"
      ],
      [
        "type",
        "text"
      ],
      [
        "required",
        false
      ],
      [
        "help",
        "e.g. https://radicale.example.com/user/calendar/ (required for caldav backend)"
      ]
    ],
    [
      [
        "key",
        "caldav_username"
      ],
      [
        "label",
        "CalDAV Username"
      ],
      [
        "type",
        "text"
      ],
      [
        "required",
        false
      ],
      [
        "help",
        "Required for caldav backend"
      ]
    ],
    [
      [
        "key",
        "caldav_password"
      ],
      [
        "label",
        "CalDAV Password"
      ],
      [
        "type",
        "secret"
      ],
      [
        "required",
        false
      ],
      [
        "help",
        "Required for caldav backend"
      ]
    ],
    [
      [
        "key",
        "google_calendar_credentials"
      ],
      [
        "label",
        "Google service account JSON (path or inline)"
      ],
      [
        "type",
        "secret"
      ],
      [
        "required",
        false
      ],
      [
        "help",
        "Required for google backend (service account auth)"
      ]
    ],
    [
      [
        "key",
        "google_calendar_id"
      ],
      [
        "label",
        "Google Calendar ID"
      ],
      [
        "type",
        "text"
      ],
      [
        "required",
        false
      ],
      [
        "help",
        "Default: primary. Use a specific calendar ID for shared calendars"
      ]
    ],
    [
      [
        "key",
        "google_calendar_client_id"
      ],
      [
        "label",
        "Google OAuth2 Client ID"
      ],
      [
        "type",
        "text"
      ],
      [
        "required",
        false
      ],
      [
        "help",
        "For OAuth2 refresh token auth (alternative to service account)"
      ]
    ],
    [
      [
        "key",
        "google_calendar_client_secret"
      ],
      [
        "label",
        "Google OAuth2 Client Secret"
      ],
      [
        "type",
        "secret"
      ],
      [
        "required",
        false
      ],
      [
        "help",
        "For OAuth2 refresh token auth"
      ]
    ],
    [
      [
        "key",
        "google_calendar_refresh_token"
      ],
      [
        "label",
        "Google OAuth2 Refresh Token"
      ],
      [
        "type",
        "secret"
      ],
      [
        "required",
        false
      ],
      [
        "help",
        "For OAuth2 refresh token auth"
      ]
    ]
  ],
  "pip_dependencies": [
    "caldav",
    "icalendar"
  ],
  "free": true,
  "bundled": true,
  "marketplace": {
    "icon": "calendar_month",
    "tagline": "Full calendar management from WhatsApp — CalDAV or Google Calendar",
    "category": "productivity",
    "long_description": "View your agenda, find free slots, and create events using natural language — all from WhatsApp. Refuses overlapping events and prompts you to confirm, cancel, or draft a polite reschedule reply. Set availability preferences (no weekends, work hours, blocked days) so the AI agent never offers a time you can't make. Supports CalDAV (Radicale, Nextcloud) and Google Calendar. Recurring events, ICS imports, holiday syncing."
  }
}
