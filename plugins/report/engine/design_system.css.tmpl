{# Parameterised Design System CSS — CupBots Report Engine #}
{# Jinja2 template: render with palette dict + company_name + font overrides #}
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&family=DM+Serif+Display&display=swap');

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  /* Brand palette — parameterised */
  --primary:        {{ primary        | default('#2E7D32') }};
  --primary-light:  {{ primary_light  | default('#4CAF50') }};
  --primary-pale:   {{ primary_pale   | default('#E8F5E9') }};
  --accent:         {{ accent         | default('#C8A951') }};
  --dark:           {{ dark           | default('#37474F') }};
  --secondary:      {{ secondary      | default('#795548') }};
  --navy:           {{ navy           | default('#1F4E79') }};

  /* Text colours */
  --text-primary:   {{ text_primary   | default('#263238') }};
  --text-secondary: {{ text_secondary | default('#546E7A') }};
  --text-muted:     {{ text_muted     | default('#90A4AE') }};

  /* Backgrounds */
  --bg-page:  {{ bg_page  | default('#FFFFFF') }};
  --bg-warm:  {{ bg_warm  | default('#F8F6F0') }};
  --bg-green: {{ bg_green | default('#F1F8E9') }};

  /* Borders */
  --border-light: {{ border_light | default('#E0E0E0') }};
  --border-green: {{ border_green | default('#C8E6C9') }};

  /* Semantic colours (fixed — not brand-dependent) */
  --white: #FFFFFF;
  --economic-blue:    #1565C0;
  --social-orange:    #E65100;
  --governance-purple: #6A1B9A;
  --risk-red:    #C62828;
  --risk-amber:  #F57F17;
  --risk-green:  #2E7D32;
  --table-alt:   #F2F7FB;

  /* Typography */
  --font-display: {{ font_display | default("'DM Serif Display', Georgia, serif") }};
  --font-body:    {{ font_body    | default("'DM Sans', 'Helvetica Neue', Arial, sans-serif") }};

  /* Print-scaled sizes (1.85x screen for ~192 DPI A4 at 1587px wide) */
  --h1-size: 78px;
  --h2-size: 52px;
  --h3-size: 37px;
  --h4-size: 30px;
  --body-size: 25px;
  --small-size: 22px;
  --caption-size: 20px;
  --body-line: 1.6;
}

/* ====================================================================
   CSS PAGED MEDIA — browser handles pagination, headers, footers
   ==================================================================== */

@page {
  size: A4;
  margin: 22mm 18mm 24mm 18mm;

  @bottom-left {
    content: "{{ company_name | default('Company Name') }}";
    font: 9pt var(--font-body);
    color: var(--text-muted);
  }
  @bottom-right {
    content: counter(page);
    font: 9pt var(--font-body);
    color: var(--text-muted);
    font-weight: 700;
  }
}

/* Hero pages (cover, dividers, back cover) — full bleed, no margins */
@page hero {
  margin: 0;
  @bottom-left  { content: none; }
  @bottom-right { content: none; }
}

/* First page (cover) — also full bleed */
@page :first {
  margin: 0;
  @bottom-left  { content: none; }
  @bottom-right { content: none; }
}

/* Pagination flow control */
section.report-section { break-before: page; }
h2, h3 { break-after: avoid; }
p { orphans: 3; widows: 3; }
table, .metric-card, .quote-panel, .target-card, .card,
.numbered-card, .callout-box, .cert-badge, .zt-card,
.signature-block { break-inside: avoid; }
thead { display: table-header-group; }
tbody tr { break-inside: avoid; }

/* ====================================================================
   BASE DOCUMENT STYLES
   ==================================================================== */

html {
  font-family: var(--font-body);
  font-size: var(--body-size);
  line-height: var(--body-line);
  color: var(--text-primary);
  background: var(--bg-page);
}

/* ====================================================================
   HERO SECTIONS — pure CSS, no Gemini
   ==================================================================== */

.hero-cover, .hero-divider, .hero-back {
  page: hero;
  break-before: page;
  break-after: page;
  width: 100%;
  min-height: 100vh;
  position: relative;
  display: flex;
  align-items: flex-end;
  background-size: cover;
  background-position: center;
  color: var(--white);
}

.hero-overlay {
  width: 100%;
  padding: 80px 60px;
  /* CMYK-safe: solid dark tint instead of rgba gradient */
  background: linear-gradient(to top, var(--dark) 0%, transparent 100%);
}

.hero-title {
  font-family: var(--font-display);
  font-size: 96px;
  line-height: 1.1;
  color: var(--white);
  margin-bottom: 16px;
}
.hero-subtitle {
  font-family: var(--font-body);
  font-size: 32px;
  color: var(--white);
  opacity: 0.9;
}
.hero-logo {
  position: absolute;
  top: 40px;
  right: 60px;
}
.hero-logo img { height: 64px; }

/* Section divider hero */
.hero-divider {
  align-items: center;
  justify-content: center;
  text-align: center;
}
.hero-divider .hero-overlay {
  background: linear-gradient(to top, var(--dark) 0%, transparent 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}
.hero-divider .divider-section-label {
  font-family: var(--font-body);
  font-size: var(--small-size);
  color: var(--white);
  text-transform: uppercase;
  letter-spacing: 4px;
  margin-bottom: 16px;
  opacity: 0.8;
}
.hero-divider .divider-title {
  font-family: var(--font-display);
  font-size: 80px;
  color: var(--white);
  line-height: 1.15;
  margin-bottom: 24px;
}
.hero-divider .divider-accent {
  width: 80px;
  height: 4px;
  background: var(--accent);
  margin: 0 auto 28px;
}
.hero-divider .divider-intro {
  font-size: var(--body-size);
  color: var(--white);
  opacity: 0.85;
  line-height: 1.6;
  max-width: 700px;
}

/* Back cover */
.hero-back {
  align-items: center;
  justify-content: center;
  background-color: var(--dark);
}
.hero-back .hero-overlay {
  background: none;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

/* ====================================================================
   SECTION HEADERS
   ==================================================================== */

.section-number {
  font-family: var(--font-body);
  font-size: var(--small-size);
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 3px;
  margin-bottom: 14px;
}
.section-title {
  font-family: var(--font-display);
  font-size: var(--h1-size);
  color: var(--primary);
  line-height: 1.15;
  margin-bottom: 36px;
}
.subsection-title {
  font-family: var(--font-display);
  font-size: var(--h2-size);
  color: var(--dark);
  line-height: 1.2;
  margin-top: 48px;
  margin-bottom: 24px;
}
.sub-subsection-title {
  font-family: var(--font-body);
  font-size: var(--h3-size);
  font-weight: 700;
  color: var(--primary);
  margin-top: 36px;
  margin-bottom: 18px;
}
h4 {
  font-family: var(--font-body);
  font-size: var(--h4-size);
  font-weight: 700;
  color: var(--dark);
  margin-top: 28px;
  margin-bottom: 14px;
}

/* ====================================================================
   BODY TEXT
   ==================================================================== */

.body-text {
  font-size: var(--body-size);
  line-height: var(--body-line);
  color: var(--text-primary);
  margin-bottom: 22px;
  text-align: justify;
  hyphens: auto;
}
.drop-cap::first-letter {
  font-family: var(--font-display);
  font-size: 130px;
  float: left;
  line-height: 0.8;
  padding-right: 14px;
  padding-top: 6px;
  color: var(--primary);
}
.body-text strong { font-weight: 700; color: var(--dark); }

/* ====================================================================
   DATA TABLES
   ==================================================================== */

.data-table {
  width: 100%;
  border-collapse: collapse;
  margin: 28px 0;
  font-size: var(--small-size);
}
.data-table thead th {
  background: var(--primary);
  color: var(--white);
  font-weight: 700;
  text-align: left;
  padding: 16px 18px;
  font-size: var(--small-size);
  border: none;
}
.data-table thead th.num { text-align: right; }
.data-table tbody td {
  padding: 14px 18px;
  border-bottom: 1px solid var(--border-light);
  vertical-align: top;
}
.data-table tbody td.num { text-align: right; font-variant-numeric: tabular-nums; }
.data-table tbody td.bold { font-weight: 700; }
.data-table tbody tr:nth-child(even) { background: var(--table-alt); }
.data-table tbody tr.total-row { background: var(--primary-pale); font-weight: 700; }
.data-table tbody tr.total-row td { border-top: 2px solid var(--primary); }

.data-table--compact { font-size: 19px; }
.data-table--compact thead th { padding: 10px 14px; font-size: 19px; }
.data-table--compact tbody td { padding: 9px 14px; }

.data-table--kpi { font-size: 20px; }
.data-table--kpi thead th { padding: 12px 14px; font-size: 20px; }
.data-table--kpi tbody td { padding: 10px 14px; }
.data-table--kpi .sub-header td { padding: 10px 14px; font-size: 20px; }

.data-table .sub-header td {
  background: var(--primary-pale);
  font-weight: 700;
  color: var(--primary);
  font-size: var(--small-size);
  padding: 12px 18px;
  border-bottom: 2px solid var(--border-green);
}

/* ====================================================================
   METRIC CARDS
   ==================================================================== */

.metric-card {
  background: var(--bg-warm);
  border-radius: 16px;
  padding: 32px;
  text-align: center;
  break-inside: avoid;
}
.metric-card .value {
  font-family: var(--font-display);
  font-size: 60px;
  color: var(--primary);
  line-height: 1.1;
}
.metric-card .label {
  font-size: var(--small-size);
  color: var(--text-secondary);
  margin-top: 10px;
}
.metric-card .detail {
  font-size: var(--caption-size);
  color: var(--text-muted);
  margin-top: 6px;
}
.metric-card--green { background: var(--primary-pale); }
.metric-card--dark {
  background: var(--dark);
  color: var(--white);
}
.metric-card--dark .value { color: var(--accent); }
.metric-card--dark .label { color: rgba(255,255,255,0.8); }

/* ====================================================================
   CARD GRID + GENERIC CARDS
   ==================================================================== */

.card-grid { display: grid; gap: 24px; }
.card-grid--2 { grid-template-columns: 1fr 1fr; }
.card-grid--3 { grid-template-columns: 1fr 1fr 1fr; }
.card-grid--4 { grid-template-columns: 1fr 1fr 1fr 1fr; }

.card {
  background: var(--white);
  border-radius: 16px;
  padding: 32px;
  border: 1px solid var(--border-light);
  break-inside: avoid;
}
.card--accent-green { border-left: 6px solid var(--primary); }
.card--accent-brown { border-left: 6px solid var(--secondary); }
.card--accent-gold  { border-left: 6px solid var(--accent); }
.card--accent-navy  { border-left: 6px solid var(--navy); }
.card .card-title {
  font-family: var(--font-body);
  font-weight: 700;
  font-size: var(--h4-size);
  color: var(--dark);
  margin-bottom: 14px;
}
.card .card-text {
  font-size: var(--small-size);
  color: var(--text-secondary);
  line-height: 1.55;
}

/* ====================================================================
   DONUT CHART (CSS only)
   ==================================================================== */

.donut {
  width: 300px; height: 300px;
  border-radius: 50%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.donut-center {
  position: absolute;
  width: 190px; height: 190px;
  border-radius: 50%;
  background: var(--white);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.donut-center .value { font-family: var(--font-display); font-size: 30px; color: var(--dark); }
.donut-center .label { font-size: var(--caption-size); color: var(--text-muted); }

/* ====================================================================
   PROGRESS BARS
   ==================================================================== */

.progress-bar {
  width: 100%; height: 32px;
  background: var(--bg-warm);
  border-radius: 10px;
  overflow: hidden;
  margin: 6px 0;
}
.progress-bar__fill { height: 100%; border-radius: 10px; }
.progress-bar__fill--green { background: var(--primary); }
.progress-bar__fill--gold  { background: var(--accent); }
.progress-bar__fill--navy  { background: var(--navy); }

/* ====================================================================
   BADGES & PILLS
   ==================================================================== */

.rating-dots { display: inline-flex; gap: 3px; }
.rating-dots .dot { width: 16px; height: 16px; border-radius: 50%; background: var(--border-light); }
.rating-dots .dot.filled { background: var(--primary); }
.rating-dots .dot.filled-critical { background: var(--risk-red); }

.pillar-badge {
  display: inline-block;
  padding: 5px 16px;
  border-radius: 16px;
  font-size: var(--caption-size);
  font-weight: 700;
  color: var(--white);
}
.pillar-badge--env    { background: var(--primary); }
.pillar-badge--econ   { background: var(--economic-blue); }
.pillar-badge--social { background: var(--social-orange); }
.pillar-badge--gov    { background: var(--governance-purple); }

.risk-badge {
  display: inline-block;
  padding: 4px 14px;
  border-radius: 6px;
  font-size: 18px;
  font-weight: 700;
  color: var(--white);
}
.risk-badge--low      { background: var(--risk-green); }
.risk-badge--medium   { background: var(--risk-amber); }
.risk-badge--high     { background: var(--social-orange); }
.risk-badge--critical { background: var(--risk-red); }

.risk-type { display: inline-block; font-size: 18px; font-weight: 500; padding: 2px 0; }
.risk-type--physical   { color: var(--social-orange); }
.risk-type--transition { color: var(--navy); }

.zero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--primary-pale);
  border: 2px solid var(--primary);
  border-radius: 20px;
  padding: 10px 24px;
  font-weight: 700;
  color: var(--primary);
  font-size: var(--small-size);
}
.zero-badge-inline {
  display: inline-flex; align-items: center; gap: 6px;
  font-weight: 700; color: var(--primary); font-size: var(--small-size);
}
.zero-badges { display: flex; gap: 16px; flex-wrap: wrap; margin: 20px 0; }

/* ====================================================================
   QUOTE PANEL
   ==================================================================== */

.quote-panel {
  border-left: 6px solid var(--accent);
  padding: 28px 34px;
  margin: 32px 0;
  background: var(--bg-warm);
  border-radius: 0 8px 8px 0;
  break-inside: avoid;
}
.quote-panel .quote-text {
  font-family: var(--font-display);
  font-size: 32px;
  color: var(--dark);
  line-height: 1.5;
  font-style: italic;
}
.quote-panel .quote-attr {
  font-family: var(--font-body);
  font-size: var(--small-size);
  color: var(--text-muted);
  margin-top: 10px;
}

/* ====================================================================
   LAYOUT: SIDEBAR, TWO-COL, PHOTO
   ==================================================================== */

.two-col { display: flex; gap: 30px; }
.two-col .col-left  { flex: 0 0 35%; }
.two-col .col-right { flex: 1; }

.sidebar-panel {
  background: var(--primary);
  color: var(--white);
  padding: 60px 44px;
  border-radius: 0;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.sidebar-panel .quote-text {
  font-family: var(--font-display);
  font-size: 34px; line-height: 1.5;
  font-style: italic;
  color: var(--white);
}
.sidebar-panel .accent-line {
  width: 80px; height: 4px;
  background: var(--accent);
  margin: 20px 0;
}

.photo-frame { border-radius: 8px; overflow: hidden; }
.photo-frame img { width: 100%; height: 100%; object-fit: cover; display: block; }
.photo-frame .caption {
  font-size: var(--caption-size); color: var(--text-muted);
  padding: 6px 10px; text-align: center; background: var(--bg-warm);
}

/* ====================================================================
   CALLOUT, FIGURE, SIGNATURE, TOC
   ==================================================================== */

.callout-box {
  background: var(--primary-pale);
  border: 1px solid var(--border-green);
  border-radius: 8px;
  padding: 24px 28px;
  margin: 24px 0;
  break-inside: avoid;
}
.callout-box .callout-title {
  font-weight: 700; font-size: var(--small-size); color: var(--primary); margin-bottom: 4px;
}
.callout-box .callout-text {
  font-size: var(--small-size); color: var(--text-primary); line-height: 1.5;
}

.figure-embed { margin: 16px 0; text-align: center; }
.figure-embed img { max-width: 100%; border-radius: 8px; }
.figure-embed .figure-caption {
  font-size: var(--caption-size); color: var(--text-muted); margin-top: 8px; font-style: italic;
}

.signature-block {
  margin-top: 32px; padding-top: 20px;
  border-top: 3px solid var(--accent);
  display: inline-block;
  break-inside: avoid;
}
.signature-name  { font-family: var(--font-display); font-size: var(--h3-size); color: var(--dark); }
.signature-title { font-size: var(--small-size); color: var(--text-secondary); margin-top: 4px; }
.signature-company {
  font-size: var(--small-size); color: var(--text-muted);
  text-transform: uppercase; letter-spacing: 1px; margin-top: 2px;
}

.toc-entry { display: flex; align-items: baseline; margin-bottom: 10px; font-size: 25px; }
.toc-entry .toc-title { flex: 1; }
.toc-entry .toc-dots  { flex: 1; border-bottom: 1px dotted var(--text-muted); margin: 0 8px; min-width: 40px; }
.toc-entry .toc-page  { font-variant-numeric: tabular-nums; color: var(--text-secondary); font-weight: 500; }
.toc-entry--h1 { font-weight: 700; color: var(--primary); font-size: 28px; margin-top: 24px; }
.toc-entry--h2 { padding-left: 36px; color: var(--text-primary); }
.toc-entry--h3 { padding-left: 72px; font-size: 22px; color: var(--text-secondary); }

/* ====================================================================
   LISTS
   ==================================================================== */

.bullet-list { padding-left: 36px; margin: 16px 0; }
.bullet-list li { margin-bottom: 10px; font-size: var(--body-size); line-height: 1.55; }

/* ====================================================================
   NUMBERED CARDS, TARGET CARDS, POLICY CARDS
   ==================================================================== */

.numbered-cards { margin: 16px 0; }
.numbered-card { display: flex; gap: 20px; align-items: flex-start; margin-bottom: 20px; break-inside: avoid; }
.numbered-card .num-circle {
  flex-shrink: 0; width: 44px; height: 44px; border-radius: 50%;
  background: var(--primary); color: var(--white);
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 22px;
}
.numbered-card .num-text { font-size: var(--small-size); line-height: 1.5; color: var(--text-primary); }

.target-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 24px; }
.target-card {
  background: var(--primary-pale);
  border-left: 6px solid var(--primary);
  border-radius: 0 12px 12px 0;
  padding: 24px 28px;
  break-inside: avoid;
}
.target-card--gold { background: #FFF8E1; border-left-color: var(--accent); }
.target-card--navy { background: #E3F2FD; border-left-color: var(--navy); }
.target-area {
  font-family: var(--font-body); font-weight: 700;
  font-size: var(--small-size); color: var(--primary);
  text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px;
}
.target-card--gold .target-area { color: #A67C00; }
.target-card--navy .target-area { color: var(--navy); }
.target-text { font-size: var(--small-size); line-height: 1.5; color: var(--text-primary); }

.material-topics-list { display: flex; flex-wrap: wrap; gap: 10px; margin: 16px 0; }
.material-topic-tag {
  display: inline-block; padding: 6px 16px; border-radius: 20px;
  font-size: 18px; font-weight: 500;
  background: var(--bg-warm); color: var(--text-primary); border: 1px solid var(--border-light);
}

.policy-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 20px 0; }
.policy-card { background: var(--bg-warm); border-radius: 12px; padding: 20px; text-align: center; break-inside: avoid; }
.policy-icon   { font-size: 36px; margin-bottom: 8px; }
.policy-name   { font-weight: 700; font-size: var(--small-size); color: var(--dark); margin-bottom: 4px; }
.policy-detail { font-size: 18px; color: var(--text-muted); }

/* ====================================================================
   SPECIALIZED COMPONENTS
   ==================================================================== */

.training-section { margin: 20px 0; }
.training-title   { font-weight: 700; font-size: var(--small-size); color: var(--dark); margin-bottom: 12px; }
.progress-item    { margin-bottom: 14px; }
.progress-label   { font-size: 20px; color: var(--text-primary); margin-bottom: 4px; }

.qc-cards { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; margin: 20px 0; }
.qc-card  { background: var(--bg-warm); border-radius: 12px; padding: 20px; text-align: center; break-inside: avoid; }
.qc-title { font-weight: 700; font-size: var(--small-size); color: var(--dark); margin-bottom: 8px; }
.qc-text  { font-size: 18px; color: var(--text-secondary); line-height: 1.4; }

.cert-badges { display: flex; gap: 24px; margin: 20px 0; flex-wrap: wrap; }
.cert-badge  { display: flex; align-items: center; gap: 14px; padding: 16px 24px; background: var(--bg-warm); border-radius: 12px; border: 1px solid var(--border-light); break-inside: avoid; }
.cert-icon   { font-size: 40px; flex-shrink: 0; }
.cert-name   { font-weight: 700; font-size: var(--small-size); color: var(--dark); }
.cert-detail { font-size: 18px; color: var(--text-muted); }

.board-composition { display: flex; gap: 40px; align-items: center; margin: 20px 0; }
.donut-wrapper     { text-align: center; }
.donut-label       { font-size: 18px; color: var(--text-muted); margin-top: 8px; }
.committee-cards   { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; margin: 20px 0; }
.committee-card    { background: var(--bg-warm); border-radius: 12px; padding: 16px; text-align: center; break-inside: avoid; }
.committee-name    { font-weight: 700; font-size: var(--small-size); color: var(--dark); }
.committee-detail  { font-size: 18px; color: var(--text-muted); margin-top: 4px; }

.timeline { margin: 28px 0; position: relative; padding-left: 40px; }
.timeline::before { content: ''; position: absolute; left: 14px; top: 0; bottom: 0; width: 3px; background: var(--primary); border-radius: 2px; }
.timeline-item { position: relative; margin-bottom: 28px; padding-left: 20px; break-inside: avoid; }
.timeline-item::before { content: ''; position: absolute; left: -32px; top: 6px; width: 16px; height: 16px; border-radius: 50%; background: var(--primary); border: 3px solid var(--white); }
.timeline-date { font-weight: 700; font-size: var(--small-size); color: var(--primary); }
.timeline-text { font-size: 20px; color: var(--text-primary); margin-top: 4px; }

.timeline-strip { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; margin: 24px 0; }
.timeline-card { border-radius: 12px; padding: 24px; break-inside: avoid; }
.timeline-card--current { background: #E3F2FD; border-top: 4px solid #1565C0; }
.timeline-card--next    { background: #E0F2F1; border-top: 4px solid #00897B; }
.timeline-card--future  { background: #E8F5E9; border-top: 4px solid #2E7D32; }
.phase-label { font-size: 18px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 2px; }
.phase-year  { font-family: var(--font-display); font-size: 36px; color: var(--dark); margin: 4px 0; }
.phase-title { font-weight: 700; font-size: var(--small-size); color: var(--primary); margin-bottom: 8px; }
.timeline-card--next .phase-title    { color: #00897B; }
.timeline-card--future .phase-title  { color: var(--primary); }
.phase-text  { font-size: 18px; color: var(--text-secondary); line-height: 1.5; }

.zt-card { display: flex; align-items: center; gap: 16px; padding: 16px 24px; background: #FFF3F3; border-left: 5px solid #C62828; border-radius: 0 8px 8px 0; margin-bottom: 12px; break-inside: avoid; }
.zt-icon { width: 40px; height: 40px; border-radius: 50%; background: #C62828; color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 22px; flex-shrink: 0; }
.zt-category { font-weight: 700; font-size: var(--small-size); color: #C62828; }
.zt-position { font-size: 18px; color: var(--text-secondary); }

.bar-chart { margin: 20px 0; }
.bar-chart-row   { display: flex; align-items: center; margin-bottom: 12px; }
.bar-chart-label { width: 240px; font-size: 18px; flex-shrink: 0; color: var(--text-primary); }
.bar-chart-bars  { flex: 1; display: flex; gap: 4px; height: 28px; }
.bar-track       { border-radius: 4px; min-width: 4px; }
.bar-fill        { height: 100%; border-radius: 4px; color: white; font-size: 14px; font-weight: 700; display: flex; align-items: center; padding-left: 8px; min-width: 30px; }
.bar-fill--hires    { background: var(--primary); }
.bar-fill--turnover { background: var(--social-orange); }
.bar-legend { display: flex; gap: 20px; margin-top: 16px; font-size: 18px; color: var(--text-secondary); }

hr.section-divider { border: none; border-top: 2px solid var(--border-light); margin: 32px 0; }

/* ====================================================================
   UTILITIES
   ==================================================================== */

.text-center { text-align: center; }
.text-right  { text-align: right; }
.mt-8  { margin-top: 8px; }
.mt-16 { margin-top: 16px; }
.mt-24 { margin-top: 24px; }
.mb-8  { margin-bottom: 8px; }
.mb-16 { margin-bottom: 16px; }
.mb-24 { margin-bottom: 24px; }
.flex  { display: flex; }
.flex-between { justify-content: space-between; }
.flex-center  { align-items: center; }
.gap-16 { gap: 16px; }
.gap-24 { gap: 24px; }
